<style>
  .blog-page {
    padding: 160px 0 80px;
    min-height: 100vh;
    background: #fdf8f7;
  }

  .blog-page .container {
    max-width: 1100px;
  }

  .blog-section-header {
    display: flex;
    align-items: center;
    margin-bottom: 24px;
    gap: 16px;
  }

  .blog-section-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #b06a6a;
    letter-spacing: 1px;
    white-space: nowrap;
    margin: 0;
  }

  .blog-section-line {
    flex: 1;
    height: 1px;
    background: #e8d5d5;
    position: relative;
  }

  .blog-nav-btns {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .blog-nav-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid #e8d5d5;
    background: #fff;
    color: #b06a6a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    font-size: 0.85rem;
  }

  .blog-nav-btn:hover {
    background: #b06a6a;
    color: #fff;
    border-color: #b06a6a;
  }

  .blog-carousel-wrap {
    margin-bottom: 60px;
  }

  .blog-cards-track {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding-bottom: 12px;
    scrollbar-width: none;
  }

  .blog-cards-track::-webkit-scrollbar {
    display: none;
  }

  .blog-card {
    flex: 0 0 280px;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(176,106,106,0.08);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 32px rgba(176,106,106,0.18);
    text-decoration: none;
    color: inherit;
  }

  .blog-card-thumb {
    height: 150px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 900;
    color: rgba(255,255,255,0.3);
    letter-spacing: -1px;
  }

  .thumb-trouble { background: linear-gradient(135deg, #7a6a9a 0%, #4a3a6a 100%); }
  .thumb-perf    { background: linear-gradient(135deg, #b06a6a 0%, #7a3f3f 100%); }
  .thumb-rag     { background: linear-gradient(135deg, #6a9a7a 0%, #3a6a4a 100%); }

  .blog-card-body {
    padding: 16px 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .blog-tag {
    font-size: 0.82rem;
    padding: 4px 12px;
    border-radius: 20px;
    background: #f5e8e8;
    color: #b06a6a;
    font-weight: 600;
  }

  .blog-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #2d2d2d;
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
</style>

