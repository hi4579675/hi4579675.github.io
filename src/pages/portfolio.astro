---
// src/pages/portfolio.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>portfolio — hanna.log</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; background: #0d0f1a; color: #c8d3f5; min-height: 100vh; }

    nav { background: #090b14; border-bottom: 1px solid #1e2340; padding: 0 2.5rem; height: 52px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .logo { font-family: 'JetBrains Mono', monospace; font-size: 15px; color: #82aaff; font-weight: 500; letter-spacing: .06em; text-decoration: none; }
    .logo span { color: #c099ff; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #444b6a; text-decoration: none; letter-spacing: .05em; transition: color .15s; }
    .nav-links a:hover, .nav-links a.active { color: #82aaff; }

    main { max-width: 860px; margin: 0 auto; padding: 0 2rem 5rem; }

    .page-header { padding: 3.5rem 0 2rem; border-bottom: 1px solid #1e2340; }
    .page-title { font-size: 28px; font-weight: 500; color: #c8d3f5; }
    .page-title em { color: #82aaff; font-style: normal; }
    .page-desc { margin-top: .6rem; font-size: 13px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.8; }

    /* TABS */
    .tab-nav { display: flex; border-bottom: 1px solid #1e2340; margin: 1.8rem 0 1.4rem; }
    .tab-btn {
      font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #444b6a;
      background: none; border: none; padding: 8px 16px; cursor: pointer;
      letter-spacing: .05em; border-bottom: 2px solid transparent; margin-bottom: -1px;
      transition: color .15s, border-color .15s;
    }
    .tab-btn:hover { color: #c8d3f5; }
    .tab-btn.active { color: #82aaff; border-bottom-color: #82aaff; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }

    .project-card {
      background: #0f1120; border: 1px solid #1e2340; border-radius: 10px; overflow: hidden;
      transition: border-color .2s, transform .15s; display: flex; flex-direction: column;
      cursor: pointer;
    }
    .project-card:hover { border-color: #2d3561; transform: translateY(-3px); }

    /* 썸네일 */
    .card-thumb {
      position: relative; overflow: hidden;
      aspect-ratio: 16/9; flex-shrink: 0;
    }
    .card-thumb img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform .4s ease;
      display: block;
    }
    .project-card:hover .card-thumb img { transform: scale(1.07); }

    /* 썸네일 위 GitHub 아이콘 */
    .card-gh {
      position: absolute; top: 10px; right: 10px;
      width: 30px; height: 30px; border-radius: 50%;
      background: rgba(9,11,20,.75); backdrop-filter: blur(4px);
      border: 1px solid rgba(255,255,255,.12);
      display: flex; align-items: center; justify-content: center;
      color: #c8d3f5; text-decoration: none;
      opacity: 0; transform: translateY(-4px);
      transition: opacity .2s, transform .2s, background .15s;
      z-index: 2;
    }
    .card-gh svg { width: 14px; height: 14px; fill: currentColor; }
    .project-card:hover .card-gh { opacity: 1; transform: translateY(0); }
    .card-gh:hover { background: rgba(130,170,255,.3); color: #82aaff; }

    /* 카드 본문 */
    .card-body { padding: 1.1rem 1.2rem 1.3rem; display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .card-title { font-size: 14px; color: #c8d3f5; font-weight: 500; line-height: 1.35; }
    .card-desc { font-size: 12px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.7; flex: 1; }

    .card-tags { display: flex; gap: 5px; flex-wrap: wrap; }
    .tag { font-size: 10px; padding: 2px 9px; border-radius: 4px; letter-spacing: .03em; }

    .card-footer { display: flex; align-items: center; padding-top: 8px; border-top: 1px solid #1e2340; margin-top: 4px; }
    .card-gh-link { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; color: #444b6a; text-decoration: none; transition: color .15s; letter-spacing: .03em; }
    .card-gh-link:hover { color: #82aaff; }
    .card-gh-link svg { width: 13px; height: 13px; fill: currentColor; flex-shrink: 0; }
    .tb { background: rgba(130,170,255,.1);  color: #82aaff; border: 1px solid rgba(130,170,255,.2); }
    .tv { background: rgba(192,153,255,.1);  color: #c099ff; border: 1px solid rgba(192,153,255,.2); }
    .tc { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .tg { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .to { background: rgba(255,199,119,.09); color: #ffc777; border: 1px solid rgba(255,199,119,.18); }
    .tp { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.18); }

    /* MODAL */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(9,11,20,.88);
      backdrop-filter: blur(6px);
      z-index: 300;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .modal-overlay.open { display: flex; }

    .modal {
      background: #0f1120;
      border: 1px solid #2d3561;
      border-radius: 14px;
      padding: 2rem 2rem 1.8rem;
      max-width: 580px;
      width: 100%;
      max-height: 85vh;
      overflow-y: auto;
      position: relative;
      animation: modal-in .18s ease;
    }
    @keyframes modal-in {
      from { opacity: 0; transform: translateY(12px) scale(.98); }
      to   { opacity: 1; transform: translateY(0)   scale(1); }
    }

    .modal-close {
      position: absolute; top: 1rem; right: 1rem;
      background: none; border: none; color: #444b6a; cursor: pointer;
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      border-radius: 6px; transition: color .15s, background .15s;
    }
    .modal-close:hover { color: #c8d3f5; background: #1e2340; }
    .modal-close svg { width: 16px; height: 16px; stroke: currentColor; }

    .modal-emoji { font-size: 28px; line-height: 1; margin-bottom: .8rem; }
    .modal-title { font-size: 18px; font-weight: 500; color: #c8d3f5; margin-bottom: .5rem; }
    .modal-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 1.4rem; }

    .modal-section { margin-bottom: 1.4rem; }
    .modal-section-label {
      font-size: 10px; color: #444b6a; letter-spacing: .1em;
      margin-bottom: .6rem; padding-bottom: .4rem; border-bottom: 1px solid #1e2340;
    }
    .modal-section p, .modal-section li {
      font-size: 13px; color: #a9b1d6; font-family: 'Noto Sans KR', sans-serif;
      line-height: 1.85; margin-bottom: .4rem;
    }
    .modal-section ul { padding-left: 1.2rem; }
    .modal-section em { color: #86e1fc; font-style: normal; }

    .modal-links { display: flex; gap: 10px; padding-top: 1rem; border-top: 1px solid #1e2340; }
    .modal-link {
      font-size: 12px; color: #c8d3f5; text-decoration: none;
      display: inline-flex; align-items: center; gap: 5px;
      transition: color .15s; letter-spacing: .03em;
    }
    .modal-link:hover { color: #82aaff; }
    .modal-link svg { width: 14px; height: 14px; fill: currentColor; flex-shrink: 0; }

    @media (max-width: 640px) {
      .project-grid { grid-template-columns: 1fr; }
    }

    footer { border-top: 1px solid #1e2340; padding: 1.5rem 2.5rem; text-align: center; font-size: 11px; color: #2e3455; letter-spacing: .08em; }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo">hanna<span>.log</span></a>
  <div class="nav-links">
    <a href="/">home</a>
    <a href="/blog/">blog</a>
    <a href="/about/">about</a>
    <a href="/portfolio/" class="active">portfolio</a>
  </div>
</nav>

