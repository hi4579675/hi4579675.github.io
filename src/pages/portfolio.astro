---
// src/pages/portfolio.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>portfolio — hanna.log</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; background: #0d0f1a; color: #c8d3f5; min-height: 100vh; }

    nav { background: #090b14; border-bottom: 1px solid #1e2340; padding: 0 2.5rem; height: 52px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .logo { font-family: 'JetBrains Mono', monospace; font-size: 15px; color: #82aaff; font-weight: 500; letter-spacing: .06em; text-decoration: none; }
    .logo span { color: #c099ff; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #444b6a; text-decoration: none; letter-spacing: .05em; transition: color .15s; }
    .nav-links a:hover, .nav-links a.active { color: #82aaff; }

    main { max-width: 860px; margin: 0 auto; padding: 0 2rem 5rem; }

    .page-header { padding: 3.5rem 0 2rem; border-bottom: 1px solid #1e2340; }
    .page-title { font-size: 28px; font-weight: 500; color: #c8d3f5; }
    .page-title em { color: #82aaff; font-style: normal; }
    .page-desc { margin-top: .6rem; font-size: 13px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.8; }

    /* TABS */
    .tab-nav { display: flex; border-bottom: 1px solid #1e2340; margin: 1.8rem 0 1.4rem; }
    .tab-btn {
      font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #444b6a;
      background: none; border: none; padding: 8px 16px; cursor: pointer;
      letter-spacing: .05em; border-bottom: 2px solid transparent; margin-bottom: -1px;
      transition: color .15s, border-color .15s;
    }
    .tab-btn:hover { color: #c8d3f5; }
    .tab-btn.active { color: #82aaff; border-bottom-color: #82aaff; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }

    .project-card {
      background: #0f1120; border: 1px solid #1e2340; border-radius: 10px; overflow: hidden;
      transition: border-color .2s, transform .15s; display: flex; flex-direction: column;
      cursor: pointer;
    }
    .project-card:hover { border-color: #2d3561; transform: translateY(-3px); }

    /* 썸네일 */
    .card-thumb {
      position: relative; overflow: hidden;
      aspect-ratio: 16/9; flex-shrink: 0;
    }
    .card-thumb img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform .4s ease;
      display: block;
    }
    .project-card:hover .card-thumb img { transform: scale(1.07); }

    /* 썸네일 위 GitHub 아이콘 */
    .card-gh {
      position: absolute; top: 10px; right: 10px;
      width: 30px; height: 30px; border-radius: 50%;
      background: rgba(9,11,20,.75); backdrop-filter: blur(4px);
      border: 1px solid rgba(255,255,255,.12);
      display: flex; align-items: center; justify-content: center;
      color: #c8d3f5; text-decoration: none;
      opacity: 0; transform: translateY(-4px);
      transition: opacity .2s, transform .2s, background .15s;
      z-index: 2;
    }
    .card-gh svg { width: 14px; height: 14px; fill: currentColor; }
    .project-card:hover .card-gh { opacity: 1; transform: translateY(0); }
    .card-gh:hover { background: rgba(130,170,255,.3); color: #82aaff; }

    /* 카드 본문 */
    .card-body { padding: 1.2rem 1.3rem 1.4rem; display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .card-title { font-size: 15px; color: #c8d3f5; font-weight: 500; line-height: 1.35; font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; }
    .card-desc { font-size: 13px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.75; flex: 1; }

    .card-tags { display: flex; gap: 5px; flex-wrap: wrap; }
    .tag { font-size: 11px; padding: 4px 12px; border-radius: 20px; letter-spacing: .03em; }

    .card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 10px; margin-top: 2px; }
    .card-detail-link {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 12px; color: #444b6a; text-decoration: none;
      font-family: 'Noto Sans KR', sans-serif;
      transition: color .15s;
    }
    .card-detail-link:hover { color: #82aaff; }
    .card-gh-link { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; color: #2e3455; text-decoration: none; transition: color .15s; }
    .card-gh-link:hover { color: #636d94; }
    .card-gh-link svg { width: 13px; height: 13px; fill: currentColor; flex-shrink: 0; }
    .tb { background: rgba(130,170,255,.1);  color: #82aaff; border: 1px solid rgba(130,170,255,.2); }
    .tv { background: rgba(192,153,255,.1);  color: #c099ff; border: 1px solid rgba(192,153,255,.2); }
    .tc { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .tg { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .to { background: rgba(255,199,119,.09); color: #ffc777; border: 1px solid rgba(255,199,119,.18); }
    .tp { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.18); }

    /* MODAL */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(9,11,20,.88); backdrop-filter: blur(6px);
      z-index: 300; align-items: center; justify-content: center; padding: 1rem;
    }
    .modal-overlay.open { display: flex; }

    .modal {
      background: #0f1120; border: 1px solid #2d3561; border-radius: 14px;
      width: 100%; max-width: 800px; height: 90vh; max-height: 900px; overflow-y: auto;
      position: relative; transform: translateY(20px); transition: transform .25s;
    }
    .modal-overlay.open .modal { transform: translateY(0); }

    .modal-close {
      position: sticky; top: 1rem; float: right; margin: 1rem 1rem 0 0;
      background: #0d0f1a; border: 1px solid #2d3561; color: #636d94; cursor: pointer;
      width: 30px; height: 30px; border-radius: 50%; font-size: 13px;
      display: flex; align-items: center; justify-content: center;
      transition: border-color .15s, color .15s; z-index: 10;
    }
    .modal-close:hover { border-color: #82aaff; color: #82aaff; }

    .modal-header {
      display: flex; gap: 1.25rem; padding: 1.5rem 1.5rem 1.25rem;
      border-bottom: 1px solid #1e2340; align-items: flex-start;
    }
    .modal-img { width: 120px; height: 80px; object-fit: cover; border-radius: 8px; flex-shrink: 0; }
    .modal-title-wrap { display: flex; flex-direction: column; gap: .35rem; min-width: 0; }
    .modal-title { font-size: 18px; font-weight: 700; color: #c8d3f5; font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; line-height: 1.3; }
    .modal-subtitle { font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; font-size: 11px; color: #444b6a; letter-spacing: .08em; }
    .modal-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: .2rem; }
    .modal-github-btn {
      display: inline-flex; align-items: center; gap: .4rem;
      font-size: 12px; font-weight: 600; color: #82aaff;
      text-decoration: none; margin-top: .4rem; transition: opacity .15s;
    }
    .modal-github-btn:hover { opacity: .75; }

    .modal-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }

    .modal-section-title {
      font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
      color: #82aaff; margin-bottom: .6rem; padding-bottom: .4rem;
      border-bottom: 1px solid #1e2340; font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif;
    }
    .modal-text { font-size: 13.5px; color: #a9b1d6; line-height: 1.85; word-break: keep-all; font-family: 'Noto Sans KR', sans-serif; white-space: pre-wrap; }
    .modal-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .45rem; }
    .modal-list li {
      font-size: 13.5px; color: #a9b1d6; padding-left: 1rem;
      position: relative; line-height: 1.6; word-break: keep-all;
      font-family: 'Noto Sans KR', sans-serif;
    }
    .modal-list li::before { content: '·'; position: absolute; left: 0; color: #82aaff; }

    @media (max-width: 860px) {
      .modal { max-width: 100%; height: 95vh; max-height: 95vh; }
    }
    @media (max-width: 640px) {
      .project-grid { grid-template-columns: 1fr; }
      .modal { height: 100vh; max-height: 100vh; border-radius: 0; }
      .modal-header { flex-direction: column; }
      .modal-img { width: 100%; height: 140px; }
      .modal-overlay { padding: 0; align-items: flex-end; }
    }

    footer { border-top: 1px solid #1e2340; padding: 1.5rem 2.5rem; text-align: center; font-size: 11px; color: #2e3455; letter-spacing: .08em; }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo">hanna<span>.log</span></a>
  <div class="nav-links">
    <a href="/">home</a>
    <a href="/blog/">blog</a>
    <a href="/about/">about</a>
    <a href="/portfolio/" class="active">portfolio</a>
  </div>
</nav>

<main>
  <div class="page-header">
    <h1 class="page-title">port<em>folio</em></h1>
    <p class="page-desc">직접 설계하고 구현한 프로젝트들입니다.</p>
  </div>

  <div class="tab-nav">
    <button class="tab-btn active" data-tab="java">Java · Spring Boot</button>
    <button class="tab-btn" data-tab="fastapi">FastAPI · LangChain</button>
  </div>

  <!-- Java / Spring Boot -->
  <div class="tab-panel active" id="tab-java">
    <div class="project-grid">

      <div class="project-card" data-modal="onul">
        <div class="card-thumb">
          <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=800&q=80" alt="오늘뭐해" loading="lazy" />
          <a href="https://github.com/hi4579675/onul-mwhe" target="_blank" class="card-gh" onclick="event.stopPropagation()">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
          </a>
        </div>
        <div class="card-body">
          <div class="card-title">오늘 뭐해?</div>
          <div class="card-desc">하루 동선 추천 앱. 지역·기분·예산을 입력하면 AI가 점심/카페/놀거리까지 영업시간·이동시간을 고려한 하루 코스를 통째로 만들어줍니다.</div>
          <div class="card-tags">
            <span class="tag tv">FastAPI</span><span class="tag tb">Spring Boot</span><span class="tag to">Kakao API</span><span class="tag tc">LLM</span>
          </div>
          <div class="card-footer">
            <span class="card-detail-link">자세히 보기 →</span>
             
          </div>
        </div>
      </div>

      <div class="project-card" data-modal="fridge">
        <div class="card-thumb">
          <img src="https://images.unsplash.com/photo-1533743983669-94fa5c4338ec?w=800&q=80" alt="냉비서" loading="lazy" />
          <a href="https://github.com/fridge2fork-project/fridge2fork" target="_blank" class="card-gh" onclick="event.stopPropagation()">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
          </a>
        </div>
        <div class="card-body">
          <div class="card-title">냉비서 부탁해!</div>
          <div class="card-desc">1인 가구를 위한 냉장고 재료 기반 레시피 추천 서비스. 재료를 등록하면 매칭률 순으로 레시피를 추천하고, 유통기한 임박 재료 활용 챌린지로 식재료 낭비를 줄입니다.</div>
          <div class="card-tags">
            <span class="tag tb">Spring Boot</span><span class="tag tg">Python</span><span class="tag to">PostgreSQL</span>
          </div>
          <div class="card-footer">
            <span class="card-detail-link">자세히 보기 →</span>
             
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- FastAPI / LangChain -->
  <div class="tab-panel" id="tab-fastapi">
    <div class="project-grid">

      <div class="project-card" data-modal="jikimi">
        <div class="card-thumb">
          <img src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?w=800&q=80" alt="계약지킴이" loading="lazy" />
          <a href="https://github.com/hi4579675/jikimi" target="_blank" class="card-gh" onclick="event.stopPropagation()">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
          </a>
        </div>
        <div class="card-body">
          <div class="card-title">계약지킴이 (Jikimi)</div>
          <div class="card-desc">임차인을 위한 임대차 계약 AI 분석 서비스. 계약서(PDF/이미지)를 업로드하면 OCR → 법령 대조 → 독소 조항 리포트를 즉시 생성합니다.</div>
          <div class="card-tags">
            <span class="tag tv">FastAPI</span><span class="tag tb">Spring Boot</span><span class="tag tc">RAG</span><span class="tag tv">LLM</span><span class="tag to">OCR</span>
          </div>
          <div class="card-footer">
            <span class="card-detail-link">자세히 보기 →</span>
            
          </div>
        </div>
      </div>

      <div class="project-card" data-modal="review">
        <div class="card-thumb">
          <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&q=80" alt="ReView" loading="lazy" />
          <a href="https://github.com/hi4579675/ReView" target="_blank" class="card-gh" onclick="event.stopPropagation()">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
          </a>
        </div>
        <div class="card-body">
          <div class="card-title">ReView</div>
          <div class="card-desc">diff만 보는 리뷰어는 그만. 레포 전체를 RAG로 인덱싱해 변경 코드가 다른 파일에 미치는 영향까지 이해하는 AI 코드 리뷰어.</div>
          <div class="card-tags">
            <span class="tag tv">FastAPI</span><span class="tag tc">RAG</span><span class="tag tg">Python</span><span class="tag tb">GitHub Actions</span><span class="tag to">SQS</span>
          </div>
          <div class="card-footer">
            <span class="card-detail-link">자세히 보기 →</span>
             
          </div>
        </div>
      </div>

      <div class="project-card" data-modal="langchain">
        <div class="card-thumb">
          <img src="/langchain-demo.png" alt="LangChain 이슈서치" loading="lazy" />
          <a href="https://github.com/hi4579675/langchain-issue-search" target="_blank" class="card-gh" onclick="event.stopPropagation()">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
          </a>
        </div>
        <div class="card-body">
          <div class="card-title">랭체인 119</div>
          <div class="card-desc">LangChain GitHub bug 이슈 3,600+개를 벡터화한 트러블슈팅 RAG 시스템. </div>
          <div class="card-tags">
            <span class="tag tg">LangChain</span><span class="tag tc">RAG</span><span class="tag tv">FastAPI</span><span class="tag tg">Python</span><span class="tag tb">PostgreSQL</span>
          </div>
          <div class="card-footer">
            <span class="card-detail-link">자세히 보기 →</span>
            
          </div>
        </div>
      </div>

    </div>
  </div>
</main>

<!-- MODAL -->
<div class="modal-overlay" id="modal-overlay">
