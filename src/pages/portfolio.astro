---
// src/pages/portfolio.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>portfolio — hanna.log</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; background: #0d0f1a; color: #c8d3f5; min-height: 100vh; }

    nav { background: #090b14; border-bottom: 1px solid #1e2340; padding: 0 2.5rem; height: 52px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .logo { font-family: 'JetBrains Mono', monospace; font-size: 15px; color: #82aaff; font-weight: 500; letter-spacing: .06em; text-decoration: none; }
    .logo span { color: #c099ff; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #444b6a; text-decoration: none; letter-spacing: .05em; transition: color .15s; }
    .nav-links a:hover, .nav-links a.active { color: #82aaff; }

    main { max-width: 860px; margin: 0 auto; padding: 0 2rem 5rem; }

    .page-header { padding: 3.5rem 0 2rem; border-bottom: 1px solid #1e2340; }
    .page-title { font-size: 28px; font-weight: 500; color: #c8d3f5; }
    .page-title em { color: #82aaff; font-style: normal; }
    .page-desc { margin-top: .6rem; font-size: 13px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.8; }

    .section-head { padding: 1.8rem 0 1rem; }

    .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }

    .project-card {
      background: #0f1120; border: 1px solid #1e2340; border-radius: 10px; padding: 1.4rem;
      transition: border-color .2s, transform .15s; display: flex; flex-direction: column; gap: 10px;
      cursor: pointer;
    }
    .project-card:hover { border-color: #2d3561; transform: translateY(-2px); }

    .card-emoji { font-size: 22px; line-height: 1; }
    .card-title { font-size: 14px; color: #c8d3f5; font-weight: 500; line-height: 1.35; }
    .card-desc { font-size: 12px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.7; flex: 1; }

    .card-tags { display: flex; gap: 5px; flex-wrap: wrap; }
    .tag { font-size: 10px; padding: 2px 9px; border-radius: 4px; letter-spacing: .03em; }
    .tb { background: rgba(130,170,255,.1);  color: #82aaff; border: 1px solid rgba(130,170,255,.2); }
    .tv { background: rgba(192,153,255,.1);  color: #c099ff; border: 1px solid rgba(192,153,255,.2); }
    .tc { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .tg { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .to { background: rgba(255,199,119,.09); color: #ffc777; border: 1px solid rgba(255,199,119,.18); }
    .tp { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.18); }

    .card-links { display: flex; gap: 10px; margin-top: 4px; }
    .card-link { font-size: 11px; color: #444b6a; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; transition: color .15s; letter-spacing: .03em; }
    .card-link:hover { color: #82aaff; }
    .card-link svg { width: 13px; height: 13px; fill: currentColor; flex-shrink: 0; }

    /* MODAL */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(9,11,20,.88);
      backdrop-filter: blur(6px);
      z-index: 300;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .modal-overlay.open { display: flex; }

    .modal {
      background: #0f1120;
      border: 1px solid #2d3561;
      border-radius: 14px;
      padding: 2rem 2rem 1.8rem;
      max-width: 580px;
      width: 100%;
      max-height: 85vh;
      overflow-y: auto;
      position: relative;
      animation: modal-in .18s ease;
    }
    @keyframes modal-in {
      from { opacity: 0; transform: translateY(12px) scale(.98); }
      to   { opacity: 1; transform: translateY(0)   scale(1); }
    }

    .modal-close {
      position: absolute; top: 1rem; right: 1rem;
      background: none; border: none; color: #444b6a; cursor: pointer;
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      border-radius: 6px; transition: color .15s, background .15s;
    }
    .modal-close:hover { color: #c8d3f5; background: #1e2340; }
    .modal-close svg { width: 16px; height: 16px; stroke: currentColor; }

    .modal-emoji { font-size: 28px; line-height: 1; margin-bottom: .8rem; }
    .modal-title { font-size: 18px; font-weight: 500; color: #c8d3f5; margin-bottom: .5rem; }
    .modal-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 1.4rem; }

    .modal-section { margin-bottom: 1.4rem; }
    .modal-section-label {
      font-size: 10px; color: #444b6a; letter-spacing: .1em;
      margin-bottom: .6rem; padding-bottom: .4rem; border-bottom: 1px solid #1e2340;
    }
    .modal-section p, .modal-section li {
      font-size: 13px; color: #a9b1d6; font-family: 'Noto Sans KR', sans-serif;
      line-height: 1.85; margin-bottom: .4rem;
    }
    .modal-section ul { padding-left: 1.2rem; }
    .modal-section em { color: #86e1fc; font-style: normal; }

    .modal-links { display: flex; gap: 10px; padding-top: 1rem; border-top: 1px solid #1e2340; }
    .modal-link {
      font-size: 12px; color: #c8d3f5; text-decoration: none;
      display: inline-flex; align-items: center; gap: 5px;
      transition: color .15s; letter-spacing: .03em;
    }
    .modal-link:hover { color: #82aaff; }
    .modal-link svg { width: 14px; height: 14px; fill: currentColor; flex-shrink: 0; }

    @media (max-width: 640px) {
      .project-grid { grid-template-columns: 1fr; }
    }

    footer { border-top: 1px solid #1e2340; padding: 1.5rem 2.5rem; text-align: center; font-size: 11px; color: #2e3455; letter-spacing: .08em; }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo">hanna<span>.log</span></a>
  <div class="nav-links">
    <a href="/">home</a>
    <a href="/blog/">blog</a>
    <a href="/about/">about</a>
    <a href="/portfolio/" class="active">portfolio</a>
  </div>
</nav>

<main>
  <div class="page-header">
    <h1 class="page-title">port<em>folio</em></h1>
    <p class="page-desc">직접 설계하고 구현한 프로젝트들입니다.</p>
  </div>

  <div class="section-head"></div>

  <div class="project-grid">

    <div class="project-card" data-modal="jikimi">
      <div class="card-emoji">📄</div>
      <div class="card-title">계약지킴이 (Jikimi)</div>
      <div class="card-desc">
        임차인을 위한 임대차 계약 AI 분석 서비스.<br>
        계약서(PDF/이미지)를 업로드하면 OCR → 법령 대조 → 독소 조항 리포트를 즉시 생성합니다.
      </div>
      <div class="card-tags">
        <span class="tag tv">FastAPI</span>
        <span class="tag tb">Spring Boot</span>
        <span class="tag tc">RAG</span>
        <span class="tag tv">LLM</span>
        <span class="tag to">OCR</span>
      </div>
    </div>

    <div class="project-card" data-modal="onul">
      <div class="card-emoji">📍</div>
      <div class="card-title">오늘 뭐해?</div>
      <div class="card-desc">
        하루 동선 추천 앱. 지역·기분·예산을 입력하면 AI가 점심/카페/놀거리까지
        영업시간·이동시간을 고려한 하루 코스를 통째로 만들어줍니다.
      </div>
      <div class="card-tags">
        <span class="tag tv">FastAPI</span>
        <span class="tag tb">Spring Boot</span>
        <span class="tag to">Kakao API</span>
        <span class="tag tc">LLM</span>
      </div>
    </div>

    <div class="project-card" data-modal="fridge">
      <div class="card-emoji">🧊</div>
      <div class="card-title">냉비서 부탁해!</div>
      <div class="card-desc">
        1인 가구를 위한 냉장고 재료 기반 레시피 추천 서비스.
        재료를 등록하면 매칭률 순으로 레시피를 추천하고,
        유통기한 임박 재료 활용 챌린지로 식재료 낭비를 줄입니다.
      </div>
      <div class="card-tags">
        <span class="tag tb">Spring Boot</span>
        <span class="tag tg">Python</span>
        <span class="tag to">MySQL</span>
      </div>
    </div>

    <div class="project-card" data-modal="blog">
      <div class="card-emoji">✍️</div>
      <div class="card-title">hanna.log</div>
      <div class="card-desc">
        지금 보고 계신 이 블로그. 백엔드 개발 경험과 AI 파이프라인 트러블슈팅을 기록합니다.
        Astro + Starlight 기반, Tokyo Night 테마.
      </div>
      <div class="card-tags">
        <span class="tag tc">Astro</span>
        <span class="tag tg">Starlight</span>
        <span class="tag tb">GitHub Pages</span>
      </div>
    </div>

  </div>
</main>

<!-- MODAL -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal" id="modal-panel">
    <button class="modal-close" id="modal-close">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div id="modal-content"></div>
  </div>
</div>

<footer>© 2026 hanna.log · Built with Astro & Starlight</footer>

<script>
  const gh = `<svg width="14" height="14" viewBox="0 0 24 24" style="fill:currentColor;flex-shrink:0"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>`;

  const modals = {
    jikimi: {
      emoji: '📄',
      title: '계약지킴이 (Jikimi)',
      tags: `<span class="tag tv">FastAPI</span><span class="tag tb">Spring Boot</span><span class="tag tc">RAG</span><span class="tag tv">LLM</span><span class="tag to">OCR</span>`,
      sections: [
        { label: 'OVERVIEW', body: `<p>임차인을 위한 임대차 계약서 AI 분석 서비스입니다.<br>변호사 없이도 <em>서명 전에 한 번 더 읽어주는 AI</em>를 목표로 개발했습니다.</p>` },
        { label: 'FEATURES', body: `<ul><li>PDF / 이미지 계약서 업로드 → OCR 텍스트 추출</li><li>관련 법령 벡터 DB 대조 (RAG 파이프라인)</li><li>독소 조항 자동 탐지 및 리스크 리포트 생성</li><li>Spring Boot API 서버 + FastAPI AI 서버 분리 구조</li></ul>` },
        { label: 'WHAT I DID', body: `<p>여기에 본인이 담당한 역할을 적어주세요.</p>` },
      ],
      github: 'https://github.com/hi4579675/jikimi',
    },
    onul: {
      emoji: '📍',
      title: '오늘 뭐해?',
      tags: `<span class="tag tv">FastAPI</span><span class="tag tb">Spring Boot</span><span class="tag to">Kakao API</span><span class="tag tc">LLM</span>`,
      sections: [
        { label: 'OVERVIEW', body: `<p>지역·기분·예산을 입력하면 AI가 <em>하루 동선 코스</em>를 통째로 만들어주는 추천 앱입니다.</p>` },
        { label: 'FEATURES', body: `<ul><li>Kakao Map / Local API 병렬 호출로 장소 수집</li><li>Feasibility Filter — 영업시간·이동시간 사전 검증</li><li>LLM Re-rank — 기분·예산에 맞는 최종 코스 정렬</li><li>점심 → 카페 → 놀거리 순서의 하루 일정 자동 생성</li></ul>` },
        { label: 'WHAT I DID', body: `<p>여기에 본인이 담당한 역할을 적어주세요.</p>` },
      ],
      github: 'https://github.com/hi4579675/onul-mwhe',
    },
    fridge: {
      emoji: '🧊',
      title: '냉비서 부탁해!',
      tags: `<span class="tag tb">Spring Boot</span><span class="tag tg">Python</span><span class="tag to">MySQL</span>`,
      sections: [
        { label: 'OVERVIEW', body: `<p>1인 가구를 위한 냉장고 재료 기반 레시피 추천 서비스입니다.<br>식재료 낭비를 줄이는 것을 목표로 합니다.</p>` },
        { label: 'FEATURES', body: `<ul><li>보유 재료 등록 → 매칭률 순 레시피 추천</li><li>유통기한 임박 재료 우선 활용 챌린지</li><li>Python 크롤러로 레시피 데이터 수집</li><li>Spring Boot REST API + MySQL 백엔드</li></ul>` },
        { label: 'WHAT I DID', body: `<p>여기에 본인이 담당한 역할을 적어주세요.</p>` },
      ],
      github: 'https://github.com/fridge2fork-project/fridge2fork',
    },
    blog: {
      emoji: '✍️',
      title: 'hanna.log',
      tags: `<span class="tag tc">Astro</span><span class="tag tg">Starlight</span><span class="tag tb">GitHub Pages</span>`,
      sections: [
        { label: 'OVERVIEW', body: `<p>백엔드 개발 경험과 AI 파이프라인 트러블슈팅을 기록하는 기술 블로그입니다.</p>` },
        { label: 'FEATURES', body: `<ul><li>Astro 6 + Starlight 기반 정적 사이트</li><li>Tokyo Night 커스텀 테마 (CSS 전체 오버라이드)</li><li>블로그 포스트 커스텀 라우팅 (Starlight docs 우회)</li><li>GitHub Pages 자동 배포 (GitHub Actions)</li></ul>` },
        { label: 'WHAT I DID', body: `<p>디자인부터 개발까지 단독으로 설계·구현했습니다.</p>` },
      ],
      github: 'https://github.com/hi4579675/hi4579675.github.io',
    },
  };

  const overlay = document.getElementById('modal-overlay');
  const content = document.getElementById('modal-content');

  function openModal(key) {
    const m = modals[key];
    if (!m) return;
    const sections = m.sections.map(s => `
      <div class="modal-section">
        <div class="modal-section-label">${s.label}</div>
        ${s.body}
      </div>`).join('');
    content.innerHTML = `
      <div class="modal-emoji">${m.emoji}</div>
      <div class="modal-title">${m.title}</div>
      <div class="modal-tags">${m.tags}</div>
      ${sections}
      <div class="modal-links">
        <a href="${m.github}" target="_blank" class="modal-link" style="color:#c8d3f5;text-decoration:none;">${gh} GitHub</a>
      </div>`;
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.project-card').forEach(card => {
    card.addEventListener('click', () => openModal(card.dataset.modal));
  });

  document.getElementById('modal-close').addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>

</body>
</html>
