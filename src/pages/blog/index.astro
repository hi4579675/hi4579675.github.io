---
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs', (e) => e.id.startsWith('blog/'));
const posts = allDocs
  .filter((p) => p.data.date)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const catColor: Record<string, string> = {
  Redis: 'tp', 'Spring Boot': 'tb', '분산락': 'tb',
  LangChain: 'tv', Pinecone: 'tc', JPA: 'tb', QueryDSL: 'tg',
  MSA: 'tc', Kafka: 'tv', OpenAI: 'tv', RateLimit: 'to',
};

const catClass: Record<string, string> = {
  troubleshooting: 'cat-trouble',
  develops: 'cat-dev',
  performance: 'cat-perf',
  architecture: 'cat-arch',
  ai: 'cat-ai',
};
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>blog — hanna.log</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; background: #0d0f1a; color: #c8d3f5; min-height: 100vh; }

    nav { background: #090b14; border-bottom: 1px solid #1e2340; padding: 0 2.5rem; height: 52px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .logo { font-family: 'JetBrains Mono', monospace; font-size: 15px; color: #82aaff; font-weight: 500; letter-spacing: .06em; text-decoration: none; }
    .logo span { color: #c099ff; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #444b6a; text-decoration: none; letter-spacing: .05em; transition: color .15s; }
    .nav-links a:hover, .nav-links a.active { color: #82aaff; }

    main { max-width: 860px; margin: 0 auto; padding: 0 2rem 6rem; }

    .page-header { padding: 3.5rem 0 0; border-bottom: 1px solid #1e2340; padding-bottom: 1.8rem; }
    .page-title { font-size: 36px; font-weight: 500; color: #c8d3f5; margin-bottom: .5rem; }
    .page-desc { font-size: 13px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.7; }

    /* TABS — pill style */
    .tab-nav { display: flex; gap: 7px; flex-wrap: wrap; margin-top: 1.4rem; }
    .tab-btn {
      font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #444b6a;
      background: none; border: 1px solid #1e2340; border-radius: 20px;
      padding: 5px 14px; cursor: pointer; letter-spacing: .05em;
      transition: color .15s, border-color .15s, background .15s;
    }
    .tab-btn:hover { color: #c8d3f5; border-color: #2d3561; }
    .tab-btn.active { color: #82aaff; background: rgba(130,170,255,.08); border-color: rgba(130,170,255,.35); }

    .post-list { list-style: none; margin-top: 1rem; }
    .post-item { padding: 1.5rem 0; border-bottom: 1px solid #1e2340; }
    .post-item:last-child { border-bottom: none; }

    .post-top { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
    .post-title {
      font-size: 15px; font-weight: 500; color: #c8d3f5; text-decoration: none;
      font-family: 'Noto Sans KR', sans-serif; line-height: 1.4;
      transition: color .15s; flex: 1;
    }
    .post-title:hover { color: #82aaff; }

    .post-meta { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .post-date { font-size: 11px; color: #2e3455; letter-spacing: .05em; white-space: nowrap; }

    .post-excerpt { margin-top: .55rem; font-size: 13px; color: #636d94; font-family: 'Noto Sans KR', sans-serif; line-height: 1.75; }
    .post-tags { display: flex; gap: 5px; margin-top: .7rem; flex-wrap: wrap; }

    .tag { font-size: 10px; padding: 2px 9px; border-radius: 4px; letter-spacing: .03em; }
    .tb { background: rgba(130,170,255,.1);  color: #82aaff; border: 1px solid rgba(130,170,255,.2); }
    .tv { background: rgba(192,153,255,.1);  color: #c099ff; border: 1px solid rgba(192,153,255,.2); }
    .tc { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .tg { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .to { background: rgba(255,199,119,.09); color: #ffc777; border: 1px solid rgba(255,199,119,.18); }
    .tp { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.18); }

    /* category badges */
    .cat { font-size: 10px; padding: 2px 9px; border-radius: 3px; letter-spacing: .05em; }
    .cat-trouble { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.2); }
    .cat-dev     { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .cat-perf    { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .cat-arch    { background: rgba(130,170,255,.1);  color: #82aaff; border: 1px solid rgba(130,170,255,.2); }
    .cat-ai      { background: rgba(192,153,255,.1);  color: #c099ff; border: 1px solid rgba(192,153,255,.2); }

    /* PAGINATION */
    .pagination { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 2.5rem 0 0; }
    .pagination.hidden { display: none; }
    .page-btn {
      font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #444b6a;
      background: none; border: 1px solid #1e2340; border-radius: 6px;
      padding: 5px 11px; cursor: pointer; letter-spacing: .04em;
      transition: color .15s, border-color .15s, background .15s;
      min-width: 34px; text-align: center;
    }
    .page-btn:hover { color: #c8d3f5; border-color: #2d3561; }
    .page-btn.active { color: #82aaff; background: rgba(130,170,255,.08); border-color: rgba(130,170,255,.35); }
    .page-btn:disabled { opacity: .3; cursor: default; pointer-events: none; }
    .page-arrow { font-size: 13px; }

    footer { border-top: 1px solid #1e2340; padding: 1.5rem 2.5rem; text-align: center; font-size: 11px; color: #2e3455; letter-spacing: .08em; }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo">hanna<span>.log</span></a>
  <div class="nav-links">
    <a href="/">home</a>
    <a href="/blog/" class="active">blog</a>
    <a href="/about/">about</a>
    <a href="/portfolio/">portfolio</a>
  </div>
</nav>

<main>
  <div class="page-header">
    <h1 class="page-title">Blog</h1>
    <p class="page-desc" id="page-desc">백엔드 개발과 생성형 AI 파이프라인 경험을 기록합니다.</p>
    <div class="tab-nav">
      <button class="tab-btn active" data-cat="all">all</button>
      <button class="tab-btn" data-cat="develops">develops</button>
      <button class="tab-btn" data-cat="ai">ai · llm</button>
      <button class="tab-btn" data-cat="troubleshooting">troubleshooting</button>
      <button class="tab-btn" data-cat="performance">performance</button>
      <button class="tab-btn" data-cat="architecture">architecture</button>
    </div>
  </div>

  <ul class="post-list">
    {posts.map((post) => {
      const slug = post.id.replace(/^blog\//, '');
      const date = new Date(post.data.date);
      const dateStr = `${date.getFullYear()}.${String(date.getMonth()+1).padStart(2,'0')}.${String(date.getDate()).padStart(2,'0')}`;
      const tags: string[] = (post.data.tags as string[]) ?? [];
      const category: string = (post.data as any).category ?? 'develops';
      const cc = catClass[category] ?? 'cat-dev';
      return (
        <li class="post-item" data-cat={category}>
          <div class="post-top">
            <a href={`/blog/${slug}/`} class="post-title">{post.data.title}</a>
            <div class="post-meta">
              <span class={`cat ${cc}`}>{category}</span>
              <span class="post-date">{dateStr}</span>
            </div>
          </div>
          {post.data.excerpt && <p class="post-excerpt">{post.data.excerpt as string}</p>}
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag) => (
                <span class={`tag ${catColor[tag] ?? 'tb'}`}>{tag}</span>
              ))}
            </div>
          )}
        </li>
      );
    })}
  </ul>

  <nav class="pagination" id="pagination" aria-label="페이지 탐색">
    <button class="page-btn page-arrow" id="pg-prev">←</button>
    <span id="pg-numbers" style="display:flex;gap:6px;"></span>
    <button class="page-btn page-arrow" id="pg-next">→</button>
  </nav>
</main>

<footer>© 2026 hanna.log · Built with Astro & Starlight</footer>

<script>
  const PER_PAGE = 10;

  const descMap: Record<string, string> = {
    all:             '백엔드 개발과 생성형 AI 파이프라인 경험을 기록합니다.',
    develops:        '프로젝트 개발 회고, 기술 선택 이유, 구현 상세를 기록합니다.',
    ai:              'LLM·RAG·임베딩 등 생성형 AI 파이프라인 설계와 실험을 기록합니다.',
    troubleshooting: '마주친 버그와 에러, 원인 분석과 해결 과정을 기록합니다.',
    performance:     '쿼리 최적화, 캐싱, 부하 테스트 등 성능 개선 경험을 기록합니다.',
    architecture:    '시스템 설계, MSA, 비동기 패턴 등 아키텍처 결정을 기록합니다.',
  };

  const descEl      = document.getElementById('page-desc')!;
  const pagination  = document.getElementById('pagination')!;
  const pgNumbers   = document.getElementById('pg-numbers')!;
  const pgPrev      = document.getElementById('pg-prev') as HTMLButtonElement;
  const pgNext      = document.getElementById('pg-next') as HTMLButtonElement;
  const allItems    = Array.from(document.querySelectorAll<HTMLElement>('.post-item'));

  let currentCat  = 'all';
  let currentPage = 1;

  function getVisibleItems(): HTMLElement[] {
    return currentCat === 'all'
      ? allItems
      : allItems.filter(item => item.dataset.cat === currentCat);
  }

  function render() {
    const items     = getVisibleItems();
    const totalPages = Math.ceil(items.length / PER_PAGE);
    const start     = (currentPage - 1) * PER_PAGE;
    const end       = start + PER_PAGE;

    // 아이템 표시 여부
    allItems.forEach(item => { item.style.display = 'none'; });
    if (currentCat === 'all') {
      items.slice(start, end).forEach(item => { item.style.display = ''; });
    } else {
      // 카테고리 탭: 페이지네이션 없이 전체 표시
      items.forEach(item => { item.style.display = ''; });
    }

    // 페이지네이션: all 탭 + 2페이지 이상일 때만 표시
    const showPagination = currentCat === 'all' && totalPages > 1;
    pagination.classList.toggle('hidden', !showPagination);

    if (!showPagination) return;

    // 번호 버튼 렌더
    pgNumbers.innerHTML = '';
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
      btn.textContent = String(i);
      btn.addEventListener('click', () => { currentPage = i; render(); });
      pgNumbers.appendChild(btn);
    }

    pgPrev.disabled = currentPage === 1;
    pgNext.disabled = currentPage === totalPages;
  }

  pgPrev.addEventListener('click', () => { if (currentPage > 1) { currentPage--; render(); } });
  pgNext.addEventListener('click', () => {
    const total = Math.ceil(getVisibleItems().length / PER_PAGE);
    if (currentPage < total) { currentPage++; render(); }
  });

  document.querySelectorAll<HTMLElement>('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCat  = btn.dataset.cat!;
      currentPage = 1;
      descEl.textContent = descMap[currentCat] ?? descMap['all'];
      render();
    });
  });

  // 초기 렌더
  render();
</script>

</body>
</html>
