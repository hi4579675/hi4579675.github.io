---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('docs', (e) => e.id.startsWith('blog/'));
  return posts
    .filter((p) => p.data.date)
    .map((post) => ({
      params: { slug: post.id.replace(/^blog\//, '') },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const date = new Date(post.data.date);
const dateStr = `${date.getFullYear()}.${String(date.getMonth()+1).padStart(2,'0')}.${String(date.getDate()).padStart(2,'0')}`;
const tags: string[] = (post.data.tags as string[]) ?? [];
const category: string = (post.data as any).category ?? 'develops';
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const catClass: Record<string, string> = {
  troubleshooting: 'cat-trouble',
  develops: 'cat-dev',
  performance: 'cat-perf',
  architecture: 'cat-arch',
};
const catColor: Record<string, string> = {
  Redis: 'tp', 'Spring Boot': 'tb', '분산락': 'tb',
  LangChain: 'tv', Pinecone: 'tc', JPA: 'tb', QueryDSL: 'tg',
  MSA: 'tc', Kafka: 'tv', OpenAI: 'tv', RateLimit: 'to',
  RAG: 'tc', LLM: 'tv', 'Fine-tuning': 'tv', 'Prompt Engineering': 'tg',
  'AI Engineering': 'tv', 'GitHub Actions': 'tgr', Docker: 'tgr',
};
const cc = catClass[category] ?? 'cat-dev';
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} — hanna.log</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; background: #0d0f1a; color: #c8d3f5; min-height: 100vh; }

    nav { background: #090b14; border-bottom: 1px solid #1e2340; padding: 0 2.5rem; height: 52px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .logo { font-family: 'JetBrains Mono', monospace; font-size: 15px; color: #82aaff; font-weight: 500; letter-spacing: .06em; text-decoration: none; }
    .logo span { color: #c099ff; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #444b6a; text-decoration: none; letter-spacing: .05em; transition: color .15s; }
    .nav-links a:hover, .nav-links a.active { color: #82aaff; }

    main { max-width: 1060px; margin: 0 auto; padding: 0 2rem 6rem; }

    /* LAYOUT */
    .post-layout {
      display: flex;
      gap: 48px;
      align-items: flex-start;
      padding-top: 3.5rem;
    }

    /* TOC */
    .toc-sidebar {
      flex: 0 0 200px;
      position: sticky;
      top: 72px;
      max-height: calc(100vh - 90px);
      overflow-y: auto;
      scrollbar-width: none;
      background: #0f1120;
      border: 1px solid #1e2340;
      border-radius: 10px;
      padding: 1.1rem 1.1rem 1.3rem;
    }
    .toc-sidebar::-webkit-scrollbar { display: none; }
    .post-content { flex: 1; min-width: 0; }

    .toc-label {
      font-size: 14px; font-weight: 500; color: #c8d3f5;
      font-family: 'Noto Sans KR', sans-serif;
      margin-bottom: .9rem; display: block;
    }
    .toc-list { list-style: none; display: flex; flex-direction: column; }

    .toc-item a {
      display: block; font-size: 13px; color: #636d94; text-decoration: none;
      padding: 5px 0; line-height: 1.55;
      transition: color .15s;
      font-family: 'Noto Sans KR', sans-serif;
    }
    .toc-item a:hover { color: #a9b1d6; }
    .toc-item a.active { color: #c8d3f5; }

    .toc-item.toc-h3 a {
      padding-left: 12px; font-size: 12px; color: #444b6a;
    }
    .toc-item.toc-h3 a:hover { color: #636d94; }
    .toc-item.toc-h3 a.active { color: #a9b1d6; }

    /* POST CONTENT */
    .post-content { min-width: 0; }

    .post-header { padding-bottom: 2.4rem; border-bottom: 1px solid #1e2340; }
    .post-meta-top { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
    .post-date { font-size: 11px; color: #2e3455; letter-spacing: .06em; }

    .post-title {
      font-size: 34px; font-weight: 500; color: #c8d3f5; line-height: 1.3;
      font-family: 'Noto Sans KR', sans-serif; margin-bottom: .9rem;
    }
    .post-excerpt-sub {
      font-size: 15px; color: #636d94; font-family: 'Noto Sans KR', sans-serif;
      line-height: 1.75; margin-bottom: 1.1rem;
    }
    .post-tags { display: flex; gap: 5px; flex-wrap: wrap; }

    /* category badges */
    .cat { font-size: 10px; padding: 2px 9px; border-radius: 3px; letter-spacing: .05em; }
    .cat-trouble { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.2); }
    .cat-dev     { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .cat-perf    { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .cat-arch    { background: rgba(130,170,255,.1);  color: #82aaff; border: 1px solid rgba(130,170,255,.2); }

    .tag { font-size: 10px; padding: 2px 9px; border-radius: 4px; letter-spacing: .03em; }
    .tb { background: rgba(130,170,255,.1);  color: #82aaff; border: 1px solid rgba(130,170,255,.2); }
    .tv { background: rgba(192,153,255,.1);  color: #c099ff; border: 1px solid rgba(192,153,255,.2); }
    .tc { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .tg { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .to { background: rgba(255,199,119,.09); color: #ffc777; border: 1px solid rgba(255,199,119,.18); }
    .tp { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.18); }
    .tgr { background: rgba(100,116,139,.1); color: #94a3b8; border: 1px solid rgba(100,116,139,.2); }

    /* PROSE */
    .prose { padding: 2.4rem 0; }
    .prose :global(p) { font-family: 'Noto Sans KR', sans-serif; font-size: 15px; color: #a9b1d6; margin-bottom: 1.3rem; line-height: 1.9; }
    .prose :global(h2) {
      font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif;
      font-size: 19px; font-weight: 500; color: #c8d3f5;
      margin: 2.4rem 0 .9rem; padding-bottom: .5rem;
      border-bottom: 1px solid #1e2340; line-height: 1.3;
    }
    .prose :global(h3) {
      font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif;
      font-size: 15px; font-weight: 500; color: #82aaff;
      margin: 1.8rem 0 .7rem; line-height: 1.4;
    }
    .prose :global(h4) { font-size: 14px; color: #c099ff; margin: 1.4rem 0 .5rem; font-weight: 500; }
    .prose :global(ul), .prose :global(ol) {
      font-family: 'Noto Sans KR', sans-serif;
      padding-left: 1.5rem; margin-bottom: 1.3rem; color: #a9b1d6; font-size: 15px;
    }
    .prose :global(li) { margin-bottom: .45rem; line-height: 1.8; }
    .prose :global(code) {
      font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif;
      background: #1a1d2e; color: #c3e88d;
      padding: 2px 6px; border-radius: 4px; font-size: 13px;
    }
    .prose :global(pre) {
      background: #0f1120; border: 1px solid #1e2340; border-radius: 8px;
      padding: 1.2rem 1.4rem; overflow-x: auto; margin-bottom: 1.3rem;
    }
    .prose :global(pre code) { background: none; padding: 0; color: #c8d3f5; font-size: 13px; line-height: 1.7; font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; }
    .prose :global(blockquote) {
      border-left: 3px solid #82aaff; padding: .6rem 1rem;
      margin: 1.2rem 0; background: #0f1120; border-radius: 0 6px 6px 0;
      font-family: 'Noto Sans KR', sans-serif; color: #636d94; font-size: 14px;
    }
    .prose :global(a) { color: #82aaff; text-decoration: none; }
    .prose :global(a:hover) { color: #9fbaff; text-decoration: underline; }
    .prose :global(hr) { border: none; border-top: 1px solid #1e2340; margin: 2rem 0; }
    .prose :global(strong) { color: #c8d3f5; font-weight: 500; }
    .prose :global(em) { color: #86e1fc; font-style: normal; }
    .prose :global(table) { width: 100%; border-collapse: collapse; margin-bottom: 1.3rem; font-size: 13px; }
    .prose :global(th) { background: #0f1120; color: #82aaff; padding: .6rem 1rem; border: 1px solid #1e2340; text-align: left; font-family: 'JetBrains Mono', monospace; }
    .prose :global(td) { padding: .5rem 1rem; border: 1px solid #1e2340; color: #a9b1d6; font-family: 'Noto Sans KR', sans-serif; }

    /* BACK LINK */
    .post-footer { padding-top: 2rem; border-top: 1px solid #1e2340; }
    .back-link { font-size: 12px; color: #444b6a; text-decoration: none; letter-spacing: .04em; transition: color .15s; display: inline-flex; align-items: center; gap: 5px; }
    .back-link:hover { color: #82aaff; }

    footer { border-top: 1px solid #1e2340; padding: 1.5rem 2.5rem; text-align: center; font-size: 11px; color: #2e3455; letter-spacing: .08em; }

    @media (max-width: 720px) {
      .post-layout { grid-template-columns: 1fr; padding-top: 2.5rem; gap: 0; }
      .toc-sidebar { display: none; }
      .post-title { font-size: 26px; }
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo">hanna<span>.log</span></a>
  <div class="nav-links">
    <a href="/">home</a>
    <a href="/blog/" class="active">blog</a>
    <a href="/about/">about</a>
    <a href="/portfolio/">portfolio</a>
  </div>
</nav>

<main>
  <div class="post-layout">

    <!-- TOC -->
    <aside class="toc-sidebar">
      {tocHeadings.length > 0 && (
        <>
          <span class="toc-label">On This Page</span>
          <ul class="toc-list">
            {tocHeadings.map((h) => (
              <li class={`toc-item toc-h${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </>
      )}
    </aside>

    <!-- CONTENT -->
    <div class="post-content">
      <div class="post-header">
        <div class="post-meta-top">
          <span class={`cat ${cc}`}>{category}</span>
          <span class="post-date">{dateStr}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        {post.data.excerpt && <p class="post-excerpt-sub">{post.data.excerpt as string}</p>}
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <span class={`tag ${catColor[tag] ?? 'tb'}`}>{tag}</span>
            ))}
          </div>
        )}
      </div>

      <div class="prose">
        <Content />
      </div>

      <div class="post-footer">
        <a href="/blog/" class="back-link">← all posts</a>
      </div>
    </div>

  </div>
</main>

<footer>© 2026 hanna.log · Built with Astro & Starlight</footer>

<script>
  // Scroll spy
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-item a');
  if (links.length > 0) {
    const headingIds = Array.from(links).map(l => l.getAttribute('href')!.slice(1));
    const headingEls = headingIds
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('active'));
            const id = entry.target.getAttribute('id');
            const active = document.querySelector<HTMLAnchorElement>(`.toc-item a[href="#${id}"]`);
            if (active) active.classList.add('active');
          }
        });
      },
      { rootMargin: '-10% 0px -80% 0px' }
    );

    headingEls.forEach(el => observer.observe(el));
  }
</script>

</body>
</html>
