---
// src/pages/index.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>hanna.log</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'JetBrains Mono', 'Noto Sans KR', sans-serif; background: #0d0f1a; color: #c8d3f5; min-height: 100vh; }

    /* NAV */
    nav { background: #090b14; border-bottom: 1px solid #1e2340; padding: 0 2.5rem; height: 52px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .logo { font-family: 'JetBrains Mono', monospace; font-size: 15px; color: #82aaff; font-weight: 500; letter-spacing: .06em; text-decoration: none; }
    .logo span { color: #c099ff; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #444b6a; text-decoration: none; letter-spacing: .05em; transition: color .15s; }
    .nav-links a:hover, .nav-links a.active { color: #82aaff; }

    main { max-width: 860px; margin: 0 auto; padding: 0 2rem 5rem; }

    /* HERO */
    .hero { padding: 3.5rem 0 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; border-bottom: 1px solid #1e2340; }
    .hero-left { flex: 1; }

    /* 타이핑 — 보더 없음, 텍스트만 */
    .typing-line { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #86e1fc; margin-bottom: 1.2rem; letter-spacing: .06em; height: 22px; }
    .typing-dot { width: 6px; height: 6px; border-radius: 50%; background: #c3e88d; flex-shrink: 0; }
    #typed-text { color: #86e1fc; }
    .cursor { display: inline-block; width: 2px; height: .85em; background: #86e1fc; margin-left: 1px; vertical-align: middle; animation: blink .7s step-end infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    h1 { font-size: 54px; font-weight: 500; color: #c8d3f5; line-height: 1.15; }
    h1 em { color: #82aaff; font-style: normal; }
    .tagline { font-size: 13px; color: #c099ff; margin-top: 8px; letter-spacing: .04em; font-family: 'Noto Sans KR', sans-serif; }
    .desc { margin-top: 1rem; font-size: 13px; color: #636d94; line-height: 1.9; font-family: 'Noto Sans KR', sans-serif; max-width: 420px; }
    .desc em { color: #86e1fc; font-style: normal; }

    .btns { display: flex; gap: 9px; margin-top: 1.8rem; flex-wrap: wrap; }
    .btn { font-size: 12px; padding: 8px 18px; border-radius: 6px; cursor: pointer; font-family: 'JetBrains Mono', monospace; border: none; letter-spacing: .04em; transition: all .15s; text-decoration: none; display: inline-block; }
    .btn-primary { background: #82aaff; color: #0d0f1a; font-weight: 500; }
    .btn-primary:hover { background: #9fbaff; }
    .btn-ghost-v { background: transparent; color: #c099ff; border: 1px solid rgba(192,153,255,.3); }
    .btn-ghost-v:hover { border-color: rgba(192,153,255,.6); }
    .btn-ghost-o { background: transparent; color: #ffc777; border: 1px solid rgba(255,199,119,.25); }
    .btn-ghost-o:hover { border-color: rgba(255,199,119,.5); }
    .btn-ghost-t { background: transparent; color: #86e1fc; border: 1px solid rgba(134,225,252,.25); }
    .btn-ghost-t:hover { border-color: rgba(134,225,252,.5); }

    /* AVATAR */
    @keyframes blob-morph {
      0%,100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
      20%     { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
      40%     { border-radius: 50% 60% 30% 60% / 30% 70% 60% 40%; }
      60%     { border-radius: 40% 50% 60% 30% / 60% 40% 50% 70%; }
      80%     { border-radius: 55% 45% 40% 60% / 45% 55% 65% 35%; }
    }
    @keyframes glow-pulse { 0%,100%{box-shadow:0 0 28px rgba(130,170,255,.22),0 0 56px rgba(130,170,255,.08)} 50%{box-shadow:0 0 44px rgba(130,170,255,.42),0 0 88px rgba(130,170,255,.16)} }
    .avatar-wrap { flex-shrink: 0; position: relative; width: 240px; height: 240px; }
    .avatar { width: 240px; height: 240px; object-fit: cover; display: block; position: relative; z-index: 1; animation: blob-morph 9s ease-in-out infinite, glow-pulse 4s ease-in-out infinite; }
    .ring1 { position: absolute; inset: -10px; border: 1.5px solid rgba(130,170,255,.22); animation: blob-morph 9s ease-in-out infinite 1.5s; }

    /* STACK */
    .stack-section { padding: 1.4rem 0; border-bottom: 1px solid #1e2340; display: flex; flex-direction: column; gap: 10px; }
    .stack-row { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
    .stack-label { font-size: 10px; color: #2e3455; letter-spacing: .1em; min-width: 90px; }
    .tag { font-size: 11px; padding: 3px 10px; border-radius: 4px; letter-spacing: .03em; }
    .tb { background: rgba(130,170,255,.1); color: #82aaff; border: 1px solid rgba(130,170,255,.2); }
    .tv { background: rgba(192,153,255,.1); color: #c099ff; border: 1px solid rgba(192,153,255,.2); }
    .tc { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .tg { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .to { background: rgba(255,199,119,.09); color: #ffc777; border: 1px solid rgba(255,199,119,.18); }
    .tp { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.18); }

    /* BLOG */
    .section-head { padding: 1.8rem 0 1rem; display: flex; align-items: center; justify-content: space-between; }
    .section-title { font-size: 11px; color: #444b6a; letter-spacing: .12em; }
    .section-more { font-size: 11px; color: #82aaff; text-decoration: none; }
    .section-more:hover { color: #9fbaff; }

    .blog-featured { background: #0f1120; border: 1px solid #1e2340; border-radius: 10px; padding: 1.4rem 1.6rem; transition: border-color .2s; text-decoration: none; display: block; margin-bottom: 12px; }
    .blog-featured:hover { border-color: #2d3561; }
    .card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: .7rem; }
    .cat { font-size: 10px; padding: 2px 9px; border-radius: 3px; letter-spacing: .05em; }
    .cat-trouble { background: rgba(255,117,127,.09); color: #ff757f; border: 1px solid rgba(255,117,127,.2); }
    .cat-ai      { background: rgba(192,153,255,.1);  color: #c099ff; border: 1px solid rgba(192,153,255,.2); }
    .cat-perf    { background: rgba(195,232,141,.09); color: #c3e88d; border: 1px solid rgba(195,232,141,.18); }
    .cat-arch    { background: rgba(134,225,252,.09); color: #86e1fc; border: 1px solid rgba(134,225,252,.18); }
    .card-date { font-size: 10px; color: #2e3455; }
    .card-title { font-size: 15px; color: #c8d3f5; font-weight: 500; margin-bottom: .5rem; line-height: 1.4; }
    .card-desc { font-size: 12px; color: #444b6a; font-family: 'Noto Sans KR', sans-serif; line-height: 1.65; }
    .card-tags { display: flex; gap: 5px; margin-top: .9rem; flex-wrap: wrap; }
    .card-tag { font-size: 10px; padding: 2px 8px; border-radius: 3px; }

    .blog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 11px; }
    .blog-card { background: #0f1120; border: 1px solid #1e2340; border-radius: 10px; padding: 1.1rem; transition: border-color .2s, transform .15s; text-decoration: none; display: block; }
    .blog-card:hover { border-color: #2d3561; transform: translateY(-2px); }
    .blog-card .card-title { font-size: 13px; }

    footer { border-top: 1px solid #1e2340; padding: 1.5rem 2.5rem; text-align: center; font-size: 11px; color: #2e3455; letter-spacing: .08em; }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo">hanna<span>.log</span></a>
  <div class="nav-links">
    <a href="/" class="active">home</a>
    <a href="/blog/">blog</a>
    <a href="/about/">about</a>
    <a href="/portfolio/">portfolio</a>
  </div>
</nav>

<main>
  <section class="hero">
    <div class="hero-left">
      <div class="typing-line">
        <span class="typing-dot"></span>
        <span id="typed-text"></span><span class="cursor"></span>
      </div>
      <h1>Hanna</h1>
      <p class="tagline">Java · Python  · SpringBoot · FastAPI  · LangChain</p>
      <p class="desc">
        서버를 설계하고 <em>AI</em>를 연결하는 엔지니어.<br>
        그 사이에서 성장합니다.
      </p>
      <div class="btns">
        <a href="/about/" class="btn btn-primary">About Me</a>
        <a href="https://github.com/hi4579675" target="_blank" class="btn btn-ghost-v">GitHub</a>
        <a href="/portfolio/" class="btn btn-ghost-o">Portfolio</a>
        <a href="https://fhtepgocprkswjfgka.tistory.com/" target="_blank" class="btn btn-ghost-t">Tistory</a>
      </div>
    </div>
    <div class="avatar-wrap">

      <div class="ring1"></div>
      <img src="/profile.jpg" alt="Hanna" class="avatar" />
    </div>
  </section>

  
  <div class="section-head">
    <a href="/blog/" class="section-more">all posts →</a>
  </div>

  <a href="/blog/redis-distributed-lock/" class="blog-featured">
    <div class="card-top">
      <span class="cat cat-trouble">troubleshooting</span>
      <span class="card-date">2026.03.25</span>
    </div>
    <div class="card-title">Redis 분산락으로 결제 동시성 문제 해결하기</div>
    <div class="card-desc">멀티 인스턴스 환경에서 동일 요청이 중복 처리되는 문제를 발견. Redisson을 활용한 분산락 적용 과정과 타임아웃 전략을 정리했습니다.</div>
    <div class="card-tags">
      <span class="card-tag tp">Redis</span>
      <span class="card-tag tv">Spring Boot</span>
      <span class="card-tag tb">분산락</span>
    </div>
  </a>

  <div class="blog-grid">
    <a href="/blog/rag-hallucination/" class="blog-card">
      <div class="card-top"><span class="cat cat-ai">ai / llm</span><span class="card-date">2026.03.18</span></div>
      <div class="card-title">RAG 파이프라인에서 Hallucination 줄이기</div>
      <div class="card-desc">LangChain + PostgreSQL 구성에서 청킹 전략과 re-ranking 적용 경험.</div>
      <div class="card-tags"><span class="card-tag tv">LangChain</span><span class="card-tag tc">PostgreSQL</span></div>
    </a>
    <a href="/blog/n-plus-one/" class="blog-card">
      <div class="card-top"><span class="cat cat-perf">performance</span><span class="card-date">2026.03.10</span></div>
      <div class="card-title">N+1 문제, QueryDSL Fetch Join으로 해결</div>
      <div class="card-desc">JPA 연관관계 조회 N+1을 QueryDSL로 개선하고 쿼리 수를 줄인 과정.</div>
      <div class="card-tags"><span class="card-tag tb">JPA</span><span class="card-tag tg">QueryDSL</span></div>
    </a>
    <a href="/blog/outbox-pattern/" class="blog-card">
      <div class="card-top"><span class="cat cat-arch">architecture</span><span class="card-date">2026.03.02</span></div>
      <div class="card-title">Outbox 패턴으로 이벤트 유실 없애기</div>
      <div class="card-desc">트랜잭션 커밋과 이벤트 발행 불일치를 Outbox 패턴으로 해결.</div>
      <div class="card-tags"><span class="card-tag tc">MSA</span><span class="card-tag tv">Kafka</span></div>
    </a>
    <a href="/blog/openai-rate-limit/" class="blog-card">
      <div class="card-top"><span class="cat cat-trouble">troubleshooting</span><span class="card-date">2026.02.22</span></div>
      <div class="card-title">OpenAI API Rate Limit 우회 전략</div>
      <div class="card-desc">고트래픽에서 rate limit에 막힌 경험과 큐잉 + 재시도 로직으로 안정화.</div>
      <div class="card-tags"><span class="card-tag tv">OpenAI</span><span class="card-tag to">RateLimit</span></div>
    </a>
  </div>
</main>

<footer>© 2026 hanna.log · Built with Astro & Starlight</footer>

<script>
  const lines = ["Backend Developer", "Generative AI Engineer", "LangChain | OpenAI"];
  let li = 0, ci = 0, deleting = false;
  const el = document.getElementById('typed-text');
  function type() {
    const cur = lines[li];
    if (!deleting) {
      el.textContent = cur.slice(0, ++ci);
      if (ci === cur.length) { deleting = true; setTimeout(type, 1400); return; }
    } else {
      el.textContent = cur.slice(0, --ci);
      if (ci === 0) { deleting = false; li = (li + 1) % lines.length; }
    }
    setTimeout(type, deleting ? 40 : 80);
  }
  type();
</script>
</body>
</html>